# Base URL of the PocketBase instance the SvelteKit BFF talks to (server-side only).
# The browser never sees or uses this value.
POCKETBASE_URL=http://127.0.0.1:8090

# Superuser credentials the BFF authenticates with to write privileged records
# (creating orders, and from Phase 6b flipping them to paid). Server-side only.
# Create the superuser with: .bin/pocketbase superuser upsert <email> <password>
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=change-me

# Stripe secret key (server-side only) for creating hosted Checkout sessions.
# Use a test-mode key (sk_test_…) in development.
STRIPE_SECRET_KEY=sk_test_xxx

# Signing secret for verifying inbound Stripe webhooks (Phase 6b payment
# fulfilment). In local dev, run:
#   stripe listen --forward-to localhost:5173/api/webhooks/stripe
# and paste the whsec_… it prints here.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Resend transactional email (EU). The order-confirmation email is sent from the
# payment webhook; the Phase 7 shipped-email runs in a pb_hooks hook. Optional in
# dev: if either of these is unset both log the email instead of sending it, so
# local checkout + fulfilment still complete end to end. MAIL_FROM must be an
# address on a Resend-verified domain. Real provisioning is a Phase 12 concern.
#
# NOTE: the pb_hooks shipped-email hook reads these via $os.getenv, so they must
# reach the PocketBase process — export them in the shell that runs
# `.bin/pocketbase serve` (this .env file is loaded by Vite, not PocketBase).
RESEND_API_KEY=
MAIL_FROM=Casa de Cuentos <pedidos@example.com>

# Flat shipping rate in CHF applied at checkout (Swiss Post, single rate).
# Optional — defaults to 8 if unset.
SHIPPING_RATE_CHF=8
