# → /etc/casadecuentos/pocketbase.env   (chmod 600, owned by root)
# The shipped-email pb_hook reads these via $os.getenv, so they must be in
# PocketBase's own process environment (not just SvelteKit's). MAIL_FROM must be
# on a Resend-verified domain.
RESEND_API_KEY=re_xxx
MAIL_FROM=Casa de Cuentos <pedidos@casadecuentos.ch>
