# /etc/caddy/Caddyfile — Casa de Cuentos. Caddy handles TLS (Let's Encrypt)
# automatically, one cert per hostname. Reload after edits:
#   sudo systemctl reload caddy
#
# PREVIEW MODE (below): only the `preview.` and `pb.` subdomains point at this
# box, so the live store can stay on Shopify at the apex. Each subdomain's cert
# issues independently via HTTP-01 — the apex does NOT need to point here.
# To GO LIVE later: point casadecuentos.ch + www A/AAAA at this box, uncomment
# the apex/www blocks at the bottom, switch ORIGIN to https://casadecuentos.ch,
# and reload.

{
	email me@sebastinez.dev
}

# Public storefront (preview). Serves the SvelteKit BFF + /api/* routes.
preview.casadecuentos.ch {
	reverse_proxy 127.0.0.1:3000
}

# PocketBase: public /api/files (book covers + OG images) and the admin UI.
# Its collection API rules are the security boundary — keep orders/rsvps/
# contact_messages superuser-only (see DEPLOY.md step 9).
pb.casadecuentos.ch {
	reverse_proxy 127.0.0.1:8090
}

