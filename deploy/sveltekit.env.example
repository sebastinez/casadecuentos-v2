# → /etc/casadecuentos/sveltekit.env   (chmod 600, owned by root)
# Runtime environment for the SvelteKit BFF (read via $env/dynamic/private).

# PocketBase, reached over its public name. /etc/hosts pins this to 127.0.0.1 on
# the box, so this traffic stays local (over Caddy's valid cert) while browsers
# and the WhatsApp/Instagram crawlers fetch cover/OG images from the same URL.
POCKETBASE_URL=https://pb.casadecuentos.ch

# adapter-node trusts this so canonical/og:url resolve to the public HTTPS apex.
ORIGIN=https://casadecuentos.ch
HOST=127.0.0.1
PORT=3000
NODE_ENV=production

# The PocketBase superuser the BFF authenticates as to write/flip orders.
POCKETBASE_ADMIN_EMAIL=admin@casadecuentos.ch
POCKETBASE_ADMIN_PASSWORD=change-me

# Stripe LIVE keys. STRIPE_WEBHOOK_SECRET comes from the prod webhook endpoint
# you create in step 10 (NOT a local `stripe listen` secret).
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Resend (EU) transactional email. MAIL_FROM must be on a Resend-verified domain.
RESEND_API_KEY=re_xxx
MAIL_FROM=Casa de Cuentos <pedidos@casadecuentos.ch>

# Flat Swiss Post shipping rate in CHF (optional; defaults to 8).
SHIPPING_RATE_CHF=8
